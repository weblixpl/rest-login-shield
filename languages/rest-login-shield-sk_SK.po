msgid ""
msgstr ""
"Project-Id-Version: REST & Login Shield 1.0.0\n"
"Language: sk_SK\n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Plural-Forms: nplurals=3; plural=(n==1) ? 0 : (n>=2 && n<=4) ? 1 : 2;\n"

msgid "Too many failed login attempts. Try again in %d minutes."
msgstr "Príliš veľa neúspešných pokusov o prihlásenie. Skúste to znova o %d min."

msgid "REST & Login Shield"
msgstr "REST & Login Shield"

msgid "Settings"
msgstr "Nastavenia"

msgid "You do not have permission to perform this action."
msgstr "Nemáte oprávnenie vykonať túto akciu."

msgid "IP %s has been unblocked."
msgstr "IP adresa %s bola odblokovaná."

msgid "Settings saved."
msgstr "Nastavenia uložené."

msgid "Your current IP: %s"
msgstr "Vaša aktuálna IP adresa: %s"

msgid "Protections"
msgstr "Ochrana"

msgid "REST API user enumeration"
msgstr "Výpis používateľov cez REST API"

msgid "Hide /wp-json/wp/v2/users for unauthenticated requests"
msgstr "Skryť /wp-json/wp/v2/users pre neprihlásené požiadavky"

msgid "REST API metadata"
msgstr "Metadáta REST API"

msgid "Strip description, gmt_offset, timezone_string from /wp-json/"
msgstr "Odstrániť description, gmt_offset, timezone_string z /wp-json/"

msgid "Author enumeration"
msgstr "Výpis autorov"

msgid "Redirect ?author=N requests to the home page"
msgstr "Presmerovať požiadavky ?author=N na hlavnú stránku"

msgid "Brute force protection"
msgstr "Ochrana proti útoku hrubou silou"

msgid "Lock out IPs after too many failed login attempts"
msgstr "Blokovať IP adresy po príliš veľa neúspešných pokusoch o prihlásenie"

msgid "Brute force settings"
msgstr "Nastavenia ochrany proti brute force"

msgid "Max failed attempts"
msgstr "Max. neúspešných pokusov"

msgid "Number of failed login attempts allowed before lockout."
msgstr "Počet povolených neúspešných pokusov o prihlásenie pred zablokovaním."

msgid "Lockout duration (minutes)"
msgstr "Doba blokovania (v minútach)"

msgid "IP whitelist"
msgstr "Biela listina IP"

msgid "One entry per line. Supports single IPv4/IPv6 or CIDR (e.g. 192.168.1.0/24). Lines starting with # are comments."
msgstr "Jeden záznam na riadok. Podporuje jednotlivé IPv4/IPv6 alebo CIDR (napr. 192.168.1.0/24). Riadky začínajúce # sú komentáre."

msgid "Save settings"
msgstr "Uložiť nastavenia"

msgid "Currently blocked IPs"
msgstr "Aktuálne blokované IP"

msgid "No IPs are currently blocked."
msgstr "V súčasnosti nie sú blokované žiadne IP."

msgid "IP address"
msgstr "IP adresa"

msgid "Failed attempts"
msgstr "Neúspešné pokusy"

msgid "Last attempt"
msgstr "Posledný pokus"

msgid "Action"
msgstr "Akcia"

msgid "Unblock"
msgstr "Odblokovať"

msgid "Recent failed login attempts"
msgstr "Posledné neúspešné pokusy o prihlásenie"

msgid "No failed login attempts recorded yet."
msgstr "Zatiaľ neboli zaznamenané žiadne neúspešné pokusy o prihlásenie."

msgid "Date"
msgstr "Dátum"

msgid "Username tried"
msgstr "Pokúšané používateľské meno"

msgid "Blocked"
msgstr "Blokované"

msgid "Yes"
msgstr "Áno"

msgid "No"
msgstr "Nie"

msgid "Trusted proxy"
msgstr "Dôveryhodná proxy"

msgid "None (use REMOTE_ADDR)"
msgstr "Žiadna (použiť REMOTE_ADDR)"

msgid "Cloudflare (CF-Connecting-IP)"
msgstr "Cloudflare (CF-Connecting-IP)"

msgid "Nginx / generic proxy (X-Real-IP)"
msgstr "Nginx / všeobecná proxy (X-Real-IP)"

msgid "Load balancer (X-Forwarded-For)"
msgstr "Load balancer (X-Forwarded-For)"

msgid "Only change this if your site is behind a reverse proxy or CDN. Leaving it as \"None\" on a directly-exposed site is the safe choice — enabling a proxy header without an actual proxy lets attackers spoof their IP and bypass brute force protection."
msgstr "Toto zmeňte len vtedy, ak je vaša stránka za reverznou proxy alebo CDN. Ponechať „Žiadna\" na priamo vystavenej stránke je bezpečnou voľbou — povolenie proxy hlavičky bez skutočnej proxy umožňuje útočníkom sfalšovať ich IP a obísť ochranu proti brute force."
