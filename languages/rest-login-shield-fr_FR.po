msgid "Too many failed login attempts. Try again in %d minutes."
msgstr "Trop de tentatives de connexion échouées. Réessayez dans %d minutes."

msgid "REST & Login Shield"
msgstr "REST & Login Shield"

msgid "Settings"
msgstr "Réglages"

msgid "You do not have permission to perform this action."
msgstr "Vous n’avez pas la permission d’effectuer cette action."

msgid "IP %s has been unblocked."
msgstr "L’IP %s a été débloquée."

msgid "Settings saved."
msgstr "Réglages enregistrés."

msgid "Your current IP: %s"
msgstr "Votre IP actuelle : %s"

msgid "Protections"
msgstr "Protections"

msgid "REST API user enumeration"
msgstr "Énumération d’utilisateurs via l’API REST"

msgid "Hide /wp-json/wp/v2/users for unauthenticated requests"
msgstr "Masquer /wp-json/wp/v2/users pour les requêtes non authentifiées"

msgid "REST API metadata"
msgstr "Métadonnées de l’API REST"

msgid "Strip description, gmt_offset, timezone_string from /wp-json/"
msgstr "Supprimer description, gmt_offset, timezone_string de /wp-json/"

msgid "Author enumeration"
msgstr "Énumération des auteurs"

msgid "Redirect ?author=N requests to the home page"
msgstr "Rediriger les requêtes ?author=N vers la page d’accueil"

msgid "Brute force protection"
msgstr "Protection contre la force brute"

msgid "Lock out IPs after too many failed login attempts"
msgstr "Bloquer les IP après trop de tentatives de connexion échouées"

msgid "Brute force settings"
msgstr "Réglages de la force brute"

msgid "Max failed attempts"
msgstr "Nombre max. de tentatives échouées"

msgid "Number of failed login attempts allowed before lockout."
msgstr "Nombre de tentatives de connexion échouées autorisées avant le blocage."

msgid "Lockout duration (minutes)"
msgstr "Durée du blocage (minutes)"

msgid "IP whitelist"
msgstr "Liste blanche d’IP"

msgid "One entry per line. Supports single IPv4/IPv6 or CIDR (e.g. 192.168.1.0/24). Lines starting with # are comments."
msgstr "Une entrée par ligne. Prend en charge IPv4/IPv6 unique ou CIDR (ex. 192.168.1.0/24). Les lignes commençant par # sont des commentaires."

msgid "Save settings"
msgstr "Enregistrer les réglages"

msgid "Currently blocked IPs"
msgstr "IP actuellement bloquées"

msgid "No IPs are currently blocked."
msgstr "Aucune IP n’est actuellement bloquée."

msgid "IP address"
msgstr "Adresse IP"

msgid "Failed attempts"
msgstr "Tentatives échouées"

msgid "Last attempt"
msgstr "Dernière tentative"

msgid "Action"
msgstr "Action"

msgid "Unblock"
msgstr "Débloquer"

msgid "Recent failed login attempts"
msgstr "Dernières tentatives de connexion échouées"

msgid "No failed login attempts recorded yet."
msgstr "Aucune tentative de connexion échouée enregistrée pour le moment."

msgid "Date"
msgstr "Date"

msgid "Username tried"
msgstr "Identifiant essayé"

msgid "Blocked"
msgstr "Bloqué"

msgid "Yes"
msgstr "Oui"

msgid "No"
msgstr "Non"
